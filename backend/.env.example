# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Google Gemini API (for Nano Banana Pro)
GEMINI_API_KEY=your-gemini-api-key

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Extra allowed origins as a regex — lets the Chrome extension
# (origin chrome-extension://<id>) call the API. Defaults to any extension;
# pin to a specific ID in production, e.g. chrome-extension://abcdefghijklmno
CORS_ORIGIN_REGEX=chrome-extension://.*

# Environment
ENVIRONMENT=development
DEBUG=true

